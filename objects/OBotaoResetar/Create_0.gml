// Controla se a janela de confirmação está visível
mostrar_confirmacao = false;

// Controla se a notificação de sucesso está visível
mostrar_notificacao = false;

// Posição horizontal inicial da notificação
// 2000 deixa ela fora da tela à direita
notif_x = 2000;

// Posição vertical da notificação
notif_y = 985;

// Contador usado para controlar o tempo da animação da notificação
tempo_notificacao = 0;

// Valor usado para animar a abertura da janela de confirmação
anim_confirmacao = 0;